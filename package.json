{
  "name": "git-geass",
  "type": "module",
  "version": "0.1.5",
  "packageManager": "pnpm@10.32.1",
  "description": "🛠️ Some quick actions for git.",
  "author": "YunYouJun <me@yunyoujun.cn>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/YunYouJun",
  "homepage": "https://github.com/YunYouJun/git-geass#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YunYouJun/git-geass.git"
  },
  "bugs": "https://github.com/YunYouJun/git-geass/issues",
  "keywords": [],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/index.d.ts"
      ]
    }
  },
  "bin": {
    "gitg": "bin/index.mjs",
    "git-geass": "bin/index.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "lint": "eslint .",
    "prepublishOnly": "nr build",
    "release": "bumpp --all && npm publish",
    "start": "tsx src/run.ts",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "c12": "^3.3.3",
    "cilicili": "^0.1.1",
    "cli-progress": "^3.12.0",
    "consola": "^3.4.2",
    "date-fns": "^4.1.0",
    "fs-extra": "^11.3.4",
    "ora": "^8.2.0",
    "prompts": "^2.4.2",
    "simple-git": "^3.33.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@antfu/ni": "^29.0.0",
    "@antfu/utils": "^9.3.0",
    "@types/cli-progress": "^3.11.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.19.15",
    "@types/prompts": "^2.4.9",
    "@types/yargs": "^17.0.35",
    "bumpp": "^11.0.1",
    "eslint": "^10.0.3",
    "lint-staged": "^16.4.0",
    "pnpm": "^10.32.1",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
